def wyszukiwanie_binarne(tablica, x):
    lewy = 0
    prawy = len(tablica) - 1
    while lewy <= prawy:
        srodek = (lewy + prawy) // 2
        if tablica[srodek] == x:
            return srodek
        elif tablica[srodek] < x:
            lewy = srodek + 1
        else:
            prawy = srodek - 1
    return -1
tablica = [1, 3, 5, 7, 9, 11]
x = 7
wynik = wyszukiwanie_binarne(tablica, x)
if wynik != -1:
    print("Znaleziono na pozycji:", wynik)
else:
    print("Nie znaleziono")
